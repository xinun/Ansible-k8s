apiVersion: apps/v1
kind: Deployment
metadata:
  annotations:
    deployment.kubernetes.io/revision: "25"
  labels:
    app: tomcat-deploy
  name: tomcat-deploy
  namespace: default
spec:
  progressDeadlineSeconds: 600
  replicas: 1
  revisionHistoryLimit: 10
  selector:
    matchLabels:
      app: tomcat-deploy
  strategy:
    rollingUpdate:
      maxSurge: 25%
      maxUnavailable: 25%
    type: RollingUpdate
  template:
    metadata:
      annotations:
        kubectl.kubernetes.io/restartedAt: "2026-03-27T11:18:38+09:00"
      labels:
        app: tomcat-deploy
    spec:
      containers:
      - image: tomcat:9.0
        imagePullPolicy: IfNotPresent
        name: tomcat
        ports:
        - containerPort: 8080
          protocol: TCP
        terminationMessagePath: /dev/termination-log
        terminationMessagePolicy: File
        volumeMounts:
        - mountPath: /usr/local/tomcat/conf/context.xml
          name: context-config
          subPath: context.xml
        - mountPath: /usr/local/tomcat/webapps/ROOT
          name: war-storage
          subPath: ROOT
        - mountPath: /usr/local/tomcat/lib/mariadb-java-client.jar
          name: war-storage
          subPath: lib/mariadb-java-client.jar
        - mountPath: /usr/local/tomcat/conf/web.xml
          name: web-config
          subPath: web.xml
      dnsPolicy: ClusterFirst
      restartPolicy: Always
      schedulerName: default-scheduler
      terminationGracePeriodSeconds: 30
      volumes:
      - configMap:
          defaultMode: 420
          name: tomcat-cm
        name: context-config
      - name: war-storage
        nfs:
          path: /root/nfs-share
          server: 10.60.100.93
      - configMap:
          defaultMode: 420
          name: tomcat-web-cm
        name: web-config
